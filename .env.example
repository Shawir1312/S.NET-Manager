# ================================================================
# S.NET Manager v2.1 — Environment Configuration Template
# ================================================================
# Salin file ini ke .env dan isi nilainya.
# File .env TIDAK BOLEH di-commit ke git.
# ================================================================

# Database
DB_HOST=localhost
DB_NAME=snet_v2
DB_USER=snet_user
DB_PASS=

# App Secret (gunakan string acak minimal 32 karakter)
# Generate: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=

# GenieACS SSL Verification (true = aktifkan verifikasi SSL, false = nonaktifkan)
GENIE_SSL_VERIFY=false
